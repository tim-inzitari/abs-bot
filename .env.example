DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-application-client-id
APP_ROLE=bot
# Optional: set to sync commands instantly to one guild while testing.
DISCORD_GUILD_ID=
DEFAULT_SEASON=2026
DEFAULT_GAME_TYPE=regular
CACHE_TTL_SECONDS=900
# Preferred for NAS/server DB deployments:
DATABASE_URL=postgresql://absbot:absbot@ump-db:5432/absbot
DATABASE_CONNECT_RETRIES=30
DATABASE_CONNECT_RETRY_SECONDS=2
POSTGRES_DB=absbot
POSTGRES_USER=absbot
POSTGRES_PASSWORD=absbot
# Optional SQLite fallback for local-only use:
# DATABASE_PATH=/app/bot-data/absbot.sqlite3
DAILY_UPDATE_HOUR_EASTERN=3
INTEGRITY_SWEEP_DAYS=7
